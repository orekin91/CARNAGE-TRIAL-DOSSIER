{
  "rules": {
    "rooms": {
      ".indexOn": ["clientId"],
      "_active": {
        ".read": true,
        "$uid": {
          ".write": true,
          ".validate": "newData.isBoolean() || newData.val() === null"
        }
      },
      "$roomCode": {
        ".read": true,
        ".write": "!data.exists() || data.child('created').exists()",
        "created":    { ".validate": "newData.isNumber()" },
        "clientId":   { ".validate": "newData.isString()" },
        "state":      { ".write": true, ".validate": "newData.hasChildren(['videoId', 'updatedAt'])" },
        "settings":   { ".write": true, ".validate": "newData.hasChildren(['lockQueue'])" },
        "queue": {
          ".write": true,
          ".validate": "newData.isString() || newData.hasChildren()"
        },
        "presence": {
          "$presenceId": {
            ".write": "!data.exists() || newData.val() === null",
            ".validate": "newData.hasChildren(['joined', 'name'])"
          }
        },
        "$other": { ".validate": false }
      }
    },
    "$other": { ".read": false, ".write": false }
  }
}
